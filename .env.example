# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pos-fjp-shop"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-min-32-chars-here"
# URL server-side saja — client menggunakan window.location.origin secara otomatis
BETTER_AUTH_URL="http://localhost:3000"

# App
NODE_ENV="development"
LOG_LEVEL="debug"

# Public
NEXT_PUBLIC_APP_NAME="FJP Shop"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_CURRENCY="IDR"
NEXT_PUBLIC_LOCALE="id-ID"

# Cloudflare R2 — untuk upload gambar (logo nota, dll)
# Buat bucket di https://dash.cloudflare.com → R2 → Create bucket
# Buat API token di R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="pos-fjp-shop"
# URL publik bucket (aktifkan Public Access di R2 bucket settings, atau gunakan custom domain)
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"

# Seed (opsional — override default admin credentials)
# SEED_ADMIN_EMAIL="admin@admin.com"
# SEED_ADMIN_PASSWORD="admin123456"
# SEED_ADMIN_NAME="Admin"
